# AI Providers（至少設一個）
ANTHROPIC_API_KEY=your_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# 預設 provider 和 model（可選）
# DEFAULT_AI_PROVIDER: claude | openai | gemini | openrouter
# DEFAULT_AI_MODEL: claude-sonnet-4-6 | gpt-4o | gemini-2.5-flash | deepseek/deepseek-chat | ... (see AI_MODELS in shared/types for full list)
DEFAULT_AI_PROVIDER=claude
DEFAULT_AI_MODEL=claude-sonnet-4-6

# Webhook 驗證密鑰（可選，設定後 /api/webhook/callback 需帶 X-Zenku-Signature header）
WEBHOOK_SECRET=
